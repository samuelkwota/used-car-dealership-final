
<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="/css/styles.css">
</head>
<body>

<div class="container">

<h1>Vehicle Inventory</h1>
<a href="/" class="back-btn">← Back to Home</a>
<form>
<input name="search" placeholder="Search make or model" value="<%= search || '' %>">
<button>Search</button>
</form>

<div class="car-grid">

<% cars.forEach(car=>{ %>
<div class="card">
<img src="<%= car.image %>">
<h3><%= car.year %> <%= car.make %> <%= car.model %></h3>
<p>$<%= car.price %></p>
<a href="/vehicle/<%= car.id %>">View</a>
</div>
<% }) %>

</div>

</div>
</body>
</html>
