
<!DOCTYPE html>
<html>
<head>
<link rel="stylesheet" href="/css/styles.css">
<title>Used Car Dealership</title>
</head>
<body>

<header class="navbar">
  <div class="container nav-content">
<div class="logo">
  <a href="/">Premium Used Cars by Kwota</a>
</div>

<nav>
  <a href="/">Home</a>
  <a href="/inventory">Inventory</a>
  <a href="/auth/login">Admin</a>
</nav>

  </div>
</header>


<div class="container">
<h2>Featured Vehicle</h2>

<% if(featured){ %>
<div class="card">
<img src="<%= featured.image %>" style="width:100%;max-height:400px;object-fit:cover">
<h3><%= featured.year %> <%= featured.make %> <%= featured.model %></h3>
<p>$<%= featured.price %></p>
<a href="/vehicle/<%= featured.id %>">View Details</a>
</div>
<% } %>

</div>
</body>
<footer class="footer">
  <div class="container">

<p>© 2026 Kwota Used Cars</p>
<p>Quality vehicles at affordable prices</p>

  </div>
</footer>

</html>
